{
  "name": "@monora/git-proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "mise exec -- tsx watch src/server.ts",
    "start": "mise exec -- tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "@monora/core": "workspace:*",
    "@monora/db": "workspace:*",
    "@monora/git": "workspace:*",
    "hono": "4.6.14"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-orm": "0.45.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
