{
  "name": "@monora/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "mise exec -- next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "mise exec -- drizzle-kit migrate",
    "db:push": "mise exec -- drizzle-kit push",
    "db:studio": "mise exec -- drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli@latest generate --config src/server/auth/index.ts --output ../../packages/db/src/auth-schema.ts -y",
    "admin": "tsx scripts/admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@better-auth/stripe": "1.6.12",
    "@monora/brand": "workspace:*",
    "@monora/core": "workspace:*",
    "@monora/db": "workspace:*",
    "@monora/git": "workspace:*",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "5.100.14",
    "@trpc/client": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "better-auth": "1.6.12",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "pg": "8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "6.12.4",
    "server-only": "0.0.1",
    "stripe": "22.2.0",
    "superjson": "2.2.6",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^22.19.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.3.0",
    "tsx": "^4.20.3",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3"
  }
}
