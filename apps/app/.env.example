# In dev these come from mise (mise.local.toml). This file documents what the
# app needs in prod / CI. The app reads them via src/env.ts (validated at boot).

# --- Database (self-hosted Postgres) ---
# App connects as the low-privilege app_user so RLS is enforced.
DATABASE_URL="postgresql://app_user:app_password@localhost:5433/monora"
# Migrations only (drizzle-kit), run as the owner role (bypasses RLS).
DATABASE_URL_OWNER="postgresql://monora_owner:owner_password@localhost:5433/monora"

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
RESEND_API_KEY=""

# --- Social login (OAuth apps) ---
GOOGLE_ID=""
GOOGLE_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs created by scripts/stripe-setup.mjs (run once per environment; pass a
# live key for production). Per-seat plans, annual = 20% off.
STARTER_PRICE_ID=""
STARTER_ANNUAL_PRICE_ID=""
TEAMS_PRICE_ID=""
TEAMS_ANNUAL_PRICE_ID=""
