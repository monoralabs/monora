# Self-hosted Monora - copy to .env and fill in, then `docker compose up -d`.
# Minimal single-org config: no billing, no object storage, no email required.

# Postgres role passwords (any strong strings; used only inside the compose
# network). Two roles by design: monora_owner (migrations, bypasses RLS) and
# app_user (the running app, RLS enforced).
POSTGRES_OWNER_PASSWORD=change-me-owner
POSTGRES_APP_PASSWORD=change-me-app

# REQUIRED. Session signing secret. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URLs the app and git proxy are reached at. The localhost defaults are
# fine for local evaluation; set real URLs (and put TLS in front) for a real host.
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_GIT_PROXY_URL=http://localhost:3002

# --- Optional ---------------------------------------------------------------

# Email delivery (Resend). Without it, magic-link / OTP / verification links are
# written to the logs instead of emailed - acceptable for single-user self-host.
# RESEND_API_KEY=
# EMAIL_FROM=Monora <noreply@your-domain>

# Billing is the managed-cloud offering only. Leave unset/false for self-host.
# BILLING_ENABLED=false

# Object storage (Cloudflare R2) for avatars/logos/media. Unset = a local-disk
# blob store under GIT_ROOT is used instead. Set ALL of account/key/secret/bucket
# to enable R2.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
